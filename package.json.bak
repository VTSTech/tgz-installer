{
  "name": "@vtstech/pi-tgz-installer",
  "version": "1.0.2",
  "description": "Pi extension that adds /tgz-install command for installing Pi packages from .tgz URLs or local files",
  "main": "tgz-installer.js",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "pi-extensions",
    "tgz",
    "installer",
    "package-manager"
  ],
  "license": "MIT",
  "author": "VTSTech",
  "homepage": "https://www.VTS-Tech.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/VTSTech/tgz-installer"
  },
  "files": [
    "tgz-installer.ts"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.66"
  },
  "pi": {
    "extensions": ["./tgz-installer.ts"]
  }
}
